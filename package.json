{
  "name": "onestillpoint",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "description": "One Still Point — a scientifically grounded, GPU-accelerated black hole visualizer.",
  "license": "MIT",
  "author": "Chris Portka",
  "homepage": "https://onestillpoint.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cportka/onestillpoint.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
